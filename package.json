{
  "name": "alexclaw-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:ui && wrangler dev",
    "dev:ui": "vite --config vite.config.ts",
    "build:ui": "vite build --config vite.config.ts",
    "deploy": "npm run build:ui && npm run d1:migrate:remote && wrangler deploy",
    "debug:live": "tsx scripts/run-live-debug.ts",
    "debug:live:all": "tsx scripts/run-live-debug.ts --all",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc -p frontend/tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "verify": "npm run typecheck && npm run typecheck:ui && npm run build:ui && npm test",
    "d1:migrate:local": "wrangler d1 migrations apply alexclaw --local",
    "d1:migrate:remote": "wrangler d1 migrations apply alexclaw --remote"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.1",
    "lucide-react": "^0.575.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260216.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wrangler": "^4.8.0"
  }
}
