{
  "name": "alexclaw-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:ui && wrangler dev",
    "dev:ui": "vite --config vite.config.ts",
    "build:ui": "vite build --config vite.config.ts",
    "deploy": "npm run build:ui && npm run d1:migrate:remote && wrangler deploy",
    "debug:live": "tsx scripts/run-live-debug.ts",
    "debug:live:all": "tsx scripts/run-live-debug.ts --all",
    "typecheck": "tsc --noEmit",
    "typecheck:ui": "tsc -p frontend/tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "verify": "npm run typecheck && npm run typecheck:ui && npm run build:ui && npm test",
    "d1:migrate:local": "wrangler d1 migrations apply alexclaw --local",
    "d1:migrate:remote": "wrangler d1 migrations apply alexclaw --remote"
  },
  "dependencies": {
    "@carbon/icons-react": "^11.67.0",
    "@carbon/react": "^1.95.0",
    "@carbon/styles": "^1.94.0",
    "hono": "^4.12.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260216.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wrangler": "^4.8.0"
  }
}
