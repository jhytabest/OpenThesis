{
  "name": "alexclaw-cloudflare",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "npm run d1:migrate:remote && wrangler deploy",
    "debug:live": "tsx scripts/run-live-debug.ts",
    "debug:live:all": "tsx scripts/run-live-debug.ts --all",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "verify": "npm run typecheck && npm test",
    "d1:migrate:local": "wrangler d1 migrations apply alexclaw --local",
    "d1:migrate:remote": "wrangler d1 migrations apply alexclaw --remote"
  },
  "dependencies": {
    "hono": "^4.8.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260216.0",
    "@types/node": "^22.13.10",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "wrangler": "^4.8.0"
  }
}
