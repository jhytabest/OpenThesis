# Runtime mode: mock or live
PROVIDER_MODE=mock
OPENAI_MODEL=gpt-5-nano

# Session
SESSION_COOKIE_NAME=sid
SESSION_TTL_DAYS=30
SESSION_SECURE_COOKIES=false
ENABLE_DEV_AUTH=true

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional override; by default callback URL is derived from request origin:
# https://<host>/auth/google/callback
GOOGLE_CALLBACK_URL=

# Providers
OPENAI_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=
OPENALEX_API_KEY=
UNPAYWALL_EMAIL=
